{
  "name": "audiobook-video-maker",
  "version": "1.0.0",
  "description": "Universal audiobook to MP4 video converter",
  "author": "Aleksandr Semykin (Александр Семыкин)",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-vite build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "build:win": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-vite build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win",
    "preview": "electron-vite preview",
    "start": "electron-vite dev",
    "test": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^25.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.0",
    "cross-env": "^10.1.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.audiobook.videomaker",
    "productName": "AudioBook Video Maker",
    "directories": {
      "output": "dist-app"
    },
    "asarUnpack": [
      "node_modules/ffmpeg-static/**",
      "node_modules/ffprobe-static/**"
    ],
    "win": {
      "target": "zip",
      "icon": "resources/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "resources/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "resources/icon.png"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ]
  }
}
